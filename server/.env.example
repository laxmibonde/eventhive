# ── SERVER ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── JWT ─────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_min_32_chars

# ── FIREBASE ────────────────────────────────────────────
# From Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── RAZORPAY ────────────────────────────────────────────
# From razorpay.com → Settings → API Keys (use TEST keys)
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── EMAIL (Nodemailer via Gmail) ─────────────────────────
# Enable 2FA on Gmail → Google Account → Security → App Passwords → Generate
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── ADMIN ───────────────────────────────────────────────
ADMIN_EMAIL=admin@eventhive.com
ADMIN_PASSWORD=Admin@1234

# ── CLIENT URL (for CORS) ───────────────────────────────
CLIENT_URL=http://localhost:5173
